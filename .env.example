# Fashion AI — environment variables (loaded by lib/main.dart via flutter_dotenv).
# Copy this file to `.env` and fill in real values. `.env` is gitignored.
#
# WARNING: `.env` is currently registered as a Flutter asset in pubspec.yaml,
# which means its contents ship inside the APK/AAB and can be extracted.
# For production, prefer `--dart-define` build flags or a server-side proxy
# so these keys never reach end-user devices.

# RapidAPI key with access to the `try-on-diffusion` product.
# https://rapidapi.com/try-on-diffusion/


# Google AI Studio key for the Generative Language API (Gemini).
# https://aistudio.google.com/app/apikey
GOOGLE_AI_API_KEY=
