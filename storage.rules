rules_version = '2';

// Fashion AI — Cloud Storage security rules.
// Authenticated users may read and write files under their own /users/{uid}/
// prefix. Any other path is denied.
service firebase.storage {
  match /b/{bucket}/o {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    match /users/{uid}/{allPaths=**} {
      allow read, write: if isOwner(uid);
    }

    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
